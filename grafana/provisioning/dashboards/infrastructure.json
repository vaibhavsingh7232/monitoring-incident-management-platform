{
  "uid": "infra",
  "title": "Infrastructure Health Dashboard",
  "tags": ["infrastructure", "sre"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "CPU Usage %",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 100, "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "orange", "value": 80 },
              { "color": "red", "value": 95 }
            ]
          }
        }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "app_cpu_usage_percent",
        "legendFormat": "CPU %"
      }]
    },
    {
      "id": 2,
      "title": "Memory Usage",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 300000000 },
              { "color": "red", "value": 450000000 }
            ]
          }
        }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "app_memory_usage_bytes{type=\"heap\"}",
        "legendFormat": "Heap Memory"
      }]
    },
    {
      "id": 3,
      "title": "Active Users",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 10 }
            ]
          }
        }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "active_users_total",
        "legendFormat": "Active Users"
      }]
    },
    {
      "id": 4,
      "title": "App Uptime",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "fixed", "fixedColor": "green" }
        }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "app_uptime_seconds",
        "legendFormat": "Uptime"
      }]
    },
    {
      "id": 5,
      "title": "CPU Usage Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 80 }
            ]
          }
        }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "app_cpu_usage_percent",
        "legendFormat": "CPU %"
      }]
    },
    {
      "id": 6,
      "title": "Memory Usage Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "app_memory_usage_bytes{type=\"heap\"}",
          "legendFormat": "Heap"
        },
        {
          "datasource": "Prometheus",
          "expr": "app_memory_usage_bytes{type=\"rss\"}",
          "legendFormat": "RSS"
        }
      ]
    },
    {
      "id": 7,
      "title": "System: Node Filesystem Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "node_filesystem_size_bytes{mountpoint=\"/\"}",
          "legendFormat": "Total"
        },
        {
          "datasource": "Prometheus",
          "expr": "node_filesystem_free_bytes{mountpoint=\"/\"}",
          "legendFormat": "Free"
        }
      ]
    },
    {
      "id": 8,
      "title": "DB Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 20 }
        }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "db_connections_active",
        "legendFormat": "Active DB Connections"
      }]
    }
  ]
}
